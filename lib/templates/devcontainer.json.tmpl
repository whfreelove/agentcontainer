{
    "name": "${PROJECT_NAME}",
    "image": "${BASE_IMAGE}",
    "containerName": "agentcontainer-${PROJECT_NAME}",

    "features": {
${FEATURES_JSON}
    },

    "mounts": [
${MOUNTS_JSON}
    ],

    "containerEnv": {
        "PROJECT_NAME": "${PROJECT_NAME}",
        "WORKSPACE_FOLDER": "${WORKSPACE_FOLDER}"
    },

    "remoteUser": "vscode",
    "updateRemoteUserUID": true,
    "workspaceFolder": "${WORKSPACE_FOLDER}",
    "workspaceMount": "",

    "postCreateCommand": "bash .agentcontainer/setup.sh",
    "postStartCommand": "for f in \"$HOME/.claude\"/.claude.json \"$HOME/.claude\"/.claude.json.backup.*; do [ -f \"$f\" ] && cp \"$f\" \"$HOME/$(basename \"$f\")\"; done",

    "runArgs": [
        "--memory=${MEMORY_LIMIT}",
        "--cpus=${CPU_LIMIT}",
        "--pids-limit=${PID_LIMIT}"
    ],

    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "${DEFAULT_SHELL}"${SHELL_PROFILES_JSON}
            }
        }
    },

    "hostRequirements": {
        "memory": "${MEMORY_LIMIT}",
        "cpus": ${CPU_LIMIT}
    }
}
