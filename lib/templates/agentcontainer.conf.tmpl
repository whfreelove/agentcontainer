# Agentcontainer Project Configuration
# Generated by agentcontainer init
# This file should be committed to version control

# Project identity
PROJECT_NAME="${PROJECT_NAME}"
WORKSPACE_FOLDER="${WORKSPACE_FOLDER}"

# Base container image
BASE_IMAGE="${BASE_IMAGE}"

# AI agents (space-separated): claude-code, opencode
AGENTS="${AGENTS}"

# Command to run the agent (executed by `agentcontainer` with no subcommand)
# Use {} placeholder for where CLI args should be inserted
# Examples:
#   "claude"                          - args append at end
#   "nix-shell --run 'claude {}'"     - args replace {}
EXEC_AGENT="${EXEC_AGENT}"

# Devcontainer features (space-separated full URIs)
# Example: "ghcr.io/devcontainers/features/python:1 ghcr.io/devcontainers/features/node:1"
FEATURES="${FEATURES}"

# Setup script to run (path relative to repo root)
SETUP_SCRIPT="${SETUP_SCRIPT}"

# Shell profile for 'agentcontainer shell' (profile name, not path)
# Define custom profiles in .agentcontainer/shell-profiles.json
# Built-in profiles: bash, zsh, sh
DEFAULT_SHELL="${DEFAULT_SHELL}"
